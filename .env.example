# =============================================================================
# MODE A — Local manual (default for `pnpm dev`): no shared server game
# =============================================================================
# Leave unset, or set false / 0 / off. Teams, questions, and scoreboard live in
# localStorage on each browser. Use /control on the same machine to manage the game.
#
# VITE_USE_REMOTE_GAME=false

# =============================================================================
# MODE B — Live shared game (Vercel / production): poll GET /api/game
# =============================================================================
# Set at build time (Vercel → Environment Variables → Production → include in build).
# VITE_USE_REMOTE_GAME=true

# Faster leaderboard updates (ms). Minimum 1500. Default ~2500.
# VITE_REMOTE_POLL_MS=1800

# --- Shared game persistence (server) — use Upstash Redis free tier OR Vercel KV ---
# Without these, the API falls back to in-memory state (not shared across instances).
#
# Upstash (REST URL + token from https://console.upstash.com ):
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# Or Vercel KV (after linking KV in the project — names may be auto-injected):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Admin session (live mode only) — server-only, never VITE_ ---
ADMIN_PASSWORD=change-me-min-4-chars
SESSION_SECRET=use-a-long-random-string-at-least-16
